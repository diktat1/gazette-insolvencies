# Companies House API key (free, register at https://developer.company-information.service.gov.uk/)
COMPANIES_HOUSE_API_KEY=your_api_key_here

# Email settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# Optional: comma-separated additional recipients
# EMAIL_CC=person2@example.com,person3@example.com

# Schedule: what time to send daily email (24h format, UK time)
DAILY_SEND_TIME=08:00

# How many days back to look for notices (default 1 for daily)
LOOKBACK_DAYS=1

# Minimum opportunity score to include in email (0-100, default 0 = include all)
MIN_OPPORTUNITY_SCORE=0

# === Outreach Settings ===
# Your name as it appears in outreach emails
OUTREACH_SENDER_NAME="Kamil Altintasoglu"

# Your phone number for callbacks
OUTREACH_SENDER_PHONE="+44 7985 250 883"

# Minimum opportunity score for outreach (0-100, default 40)
OUTREACH_MIN_SCORE=40

# Optional: Override sender email (defaults to SMTP_USER)
# OUTREACH_SENDER_EMAIL=deals@yourdomain.com

# Optional: Summary email recipient (defaults to EMAIL_TO)
# OUTREACH_SUMMARY_TO=you@yourdomain.com

# === Country modules (all default OFF; flip to true to include in the report) ===
# Romania (BPI via lege5.ro index + ANAF enrichment)
ROMANIA_ENABLED=false

# USA (CourtListener free RECAP search - corporate Chapter 7/11 filings)
USA_ENABLED=false
# Optional CourtListener API token for a higher rate limit (free at courtlistener.com)
# COURTLISTENER_TOKEN=
# Space- or comma-separated bankruptcy court ids to scan (default: major commercial courts)
# USA_COURTS=deb nysb txsb txnb njb cacb ilnb flsb

# Turkey (ilan.gov.tr / Basın İlan Kurumu - bankruptcy-law notices)
TURKEY_ENABLED=false

# Malaysia (MdI e-Insolvensi - requires a portal login; OFF until creds are set)
MALAYSIA_ENABLED=false
# MALAYSIA_USER=
# MALAYSIA_PASS=
